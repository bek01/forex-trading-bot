[Unit]
Description=Forex/Stock Trading Bot
After=network.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/trading_bot
ExecStart=/home/ubuntu/venv/bin/python3 /home/ubuntu/trading_bot/main.py
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

# Environment
EnvironmentFile=/home/ubuntu/trading_bot/.env
Environment=NUMBA_CACHE_DIR=/tmp/numba_cache
Environment=PYTHONUNBUFFERED=1

# Security hardening
NoNewPrivileges=true
ProtectSystem=strict
ReadWritePaths=/home/ubuntu/trading_bot/db /home/ubuntu/trading_bot/logs /tmp/numba_cache
ProtectHome=read-only

[Install]
WantedBy=multi-user.target
